<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DeteksiBanjir.ViewModels"
             x:Class="DeteksiBanjir.Views.AdminPage"
             Title="Admin">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <Label Text="ADMIN PANEL." Style="{StaticResource HeaderLabel}" />
            <Label Text="{Binding WelcomeMessage}" Style="{StaticResource SubHeaderLabel}" />
            <Label Text="{Binding StatusMessage}" TextColor="{StaticResource Primary}" FontSize="12" FontAttributes="Italic" Margin="0,5,0,0" />
            <BoxView HeightRequest="1" Color="{StaticResource Secondary}" Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="20">
                
                <!-- Section 1: Input Sensor Data -->
                <Frame Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="INPUT NEW SENSOR DATA" Style="{StaticResource SubHeaderLabel}" />
                        
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto" RowSpacing="10" ColumnSpacing="10">
                            <!-- Water Level -->
                            <Label Grid.Row="0" Grid.Column="0" Text="Water Level (m):" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding WaterLevel}" Keyboard="Numeric" Placeholder="e.g. 4.5" />

                            <!-- Rainfall -->
                            <Label Grid.Row="1" Grid.Column="0" Text="Rainfall (mm/h):" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Rainfall}" Keyboard="Numeric" Placeholder="e.g. 25" />

                            <!-- Discharge -->
                            <Label Grid.Row="2" Grid.Column="0" Text="Discharge (m³/s):" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Discharge}" Keyboard="Numeric" Placeholder="e.g. 80" />

                            <!-- Temperature -->
                            <Label Grid.Row="3" Grid.Column="0" Text="Temperature (°C):" VerticalOptions="Center" />
                            <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Temperature}" Keyboard="Numeric" Placeholder="e.g. 27.5" />

                            <!-- Humidity -->
                            <Label Grid.Row="4" Grid.Column="0" Text="Humidity (%):" VerticalOptions="Center" />
                            <Entry Grid.Row="4" Grid.Column="1" Text="{Binding Humidity}" Keyboard="Numeric" Placeholder="e.g. 85" />
                        </Grid>

                        <Button Text="SUBMIT DATA SENSOR" Command="{Binding SubmitSensorDataCommand}" Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Section 2: Threshold Alert Configuration -->
                <Frame Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="CONFIGURE THRESHOLDS (WATER LEVEL)" Style="{StaticResource SubHeaderLabel}" />
                        
                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" RowSpacing="10" ColumnSpacing="10">
                            <Label Grid.Row="0" Grid.Column="0" Text="Yellow Alert (m):" VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1" Text="{Binding YellowThreshold}" Keyboard="Numeric" />

                            <Label Grid.Row="1" Grid.Column="0" Text="Orange Alert (m):" VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1" Text="{Binding OrangeThreshold}" Keyboard="Numeric" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Red Alert (m):" VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1" Text="{Binding RedThreshold}" Keyboard="Numeric" />
                        </Grid>

                        <Button Text="UPDATE THRESHOLDS" Command="{Binding UpdateThresholdsCommand}" Margin="0,10,0,0" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Section 3: Recent Readings Log -->
                <Frame Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="RECENT SENSOR READINGS" Style="{StaticResource SubHeaderLabel}" />
                        <CollectionView ItemsSource="{Binding ReadingsList}" HeightRequest="200">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*, *, *, *" Padding="5" RowDefinitions="Auto">
                                        <Label Grid.Column="0" Text="{Binding Timestamp, StringFormat='{0:dd/MM HH:mm}'}" FontSize="12" />
                                        <Label Grid.Column="1" Text="{Binding WaterLevel, StringFormat='WL: {0}m'}" FontSize="12" FontAttributes="Bold" />
                                        <Label Grid.Column="2" Text="{Binding Rainfall, StringFormat='R: {0}mm'}" FontSize="12" />
                                        <Label Grid.Column="3" Text="{Binding Discharge, StringFormat='D: {0}m³'}" FontSize="12" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section 4: Users list -->
                <Frame Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="USER ACCOUNTS" Style="{StaticResource SubHeaderLabel}" />
                        <CollectionView ItemsSource="{Binding UsersList}" HeightRequest="100">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="*, *, *" Padding="5">
                                        <Label Grid.Column="0" Text="{Binding Username}" FontAttributes="Bold" />
                                        <Label Grid.Column="1" Text="{Binding Role}" />
                                        <Label Grid.Column="2" Text="{Binding IsActive, StringFormat='Active: {0}'}" FontSize="12" TextColor="Gray" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer / Action -->
        <Button Grid.Row="2" Text="LOGOUT" Style="{StaticResource AccentButton}" Command="{Binding LogoutCommand}" />
    </Grid>

</ContentPage>
